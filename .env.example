# LLM Observability Lite — Environment Variables
# Copy to .env and fill in values

# Server
PORT=8080
LOG_LEVEL=info
ENVIRONMENT=development

# Database (PostgreSQL)
DATABASE_URL=postgres://postgres:postgres@localhost:5432/observability?sslmode=disable

# Redis (for usage counters and caching)
REDIS_URL=redis://localhost:6379/0

# Auth
JWT_SECRET=change-me-to-a-random-32-char-string

# Stripe (for billing)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Optional: Usage limits per plan (override defaults)
# FREE_TRACE_LIMIT=10000
# DEV_TRACE_LIMIT=100000
# STARTUP_TRACE_LIMIT=1000000
# GROWTH_TRACE_LIMIT=10000000
