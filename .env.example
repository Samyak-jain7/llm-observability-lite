# LLM Observability Lite Configuration

# Server
HOST=0.0.0.0
PORT=8080
LOG_LEVEL=info

# Database
DATABASE_URL=sqlite+aiosqlite:///./observability.db

# Retention (days)
RETENTION_DAYS=30

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60

# Auth
API_KEYS=sk-obs-key-1,sk-obs-key-2

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:8080
